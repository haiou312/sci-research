# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code user-local state (IDE settings, local hooks, MCP approvals, etc.)
# NOTE: this is NOT .claude-plugin/ (which holds plugin metadata and IS tracked).
.claude/

# Generated output files (produced by the plugin at runtime).
# These patterns intentionally match user-facing report outputs.
# Source files in plugin subdirectories are whitelisted below.
*-research-*.md
*-news-*.md
*.pdf
*.docx

# Whitelist plugin source directories — always tracked regardless of filename.
# This protects files like agents/daily-news-writer.md and commands/daily-news-intelligence.md
# from the generated-output patterns above.
!agents/**
!commands/**
!skills/**
!hooks/**
!scripts/**
!rules/**
!contexts/**
!examples/**
!.claude-plugin/**

# Session logs
.sci-research/

# Environment
.env
.env.local
