# sci-research plugin — Gmail SMTP credentials for /daily-news-intelligence --email
#
# Copy to ~/.zshrc (or equivalent shell profile) with `export` prepended,
# or source this file from your shell startup. Never commit real values.

# Required
GOOGLE_EMAIL_USERNAME=''              # e.g. you@gmail.com
GOOGLE_EMAIL_APP_PASSWORD=''          # 16-character Gmail App Password (not your account password)

# Optional
GOOGLE_EMAIL_FROM_NAME=''             # Display name shown in the From header
GOOGLE_EMAIL_HOST='smtp.gmail.com'    # Default: smtp.gmail.com
GOOGLE_EMAIL_PORT=587                 # Default: 587 (STARTTLS). Use 465 only with an SMTP_SSL-capable script.
GOOGLE_EMAIL_START_TLS=true           # Default: true. Required for Gmail on port 587.
