{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/email-send-guard.js\"",
            "timeout": 5
          }
        ],
        "description": "Block inline SMTP / email-library sends; force use of send-report-email.py or send-briefing-email.py"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/word-count-check.js\"",
            "timeout": 10
          }
        ],
        "description": "Check article word count ≤5000 after file write"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/entity-coverage-check.js\"",
            "timeout": 10
          }
        ],
        "description": "Verify all specified entities have substantive content coverage"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/reference-validator.js\"",
            "timeout": 10
          }
        ],
        "description": "Validate all inline citations [N] have matching reference entries"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/news-freshness-check.js\"",
            "timeout": 10
          }
        ],
        "description": "Check news analysis reports contain sources from the last 7 days"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/daily-news-format-check.js\"",
            "timeout": 10
          }
        ],
        "description": "Enforce Pipeline C reference format: per-story **References** with [N] numbering, block blockquote/italic/global-refs deviations"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/research-summary.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Log research session metadata (topic, entities, source count, word count)"
      }
    ]
  }
}
