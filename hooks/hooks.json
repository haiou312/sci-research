{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hooks/email-send-guard.js\""
          }
        ],
        "description": "Block inline SMTP and require the sanctioned report-email scripts"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hooks/daily-news-format-check.js\""
          },
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hooks/monthly-news-format-check.js\""
          },
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hooks/opportunity-briefing-format-check.js\""
          }
        ],
        "description": "Validate Pipeline C, Pipeline F, and Pipeline G Markdown after apply_patch"
      }
    ]
  }
}
